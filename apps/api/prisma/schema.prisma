generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum RepoVisibility {
  PUBLIC
  PRIVATE
}

enum CollaboratorRole {
  READER
  WRITER
}

model User {
  id             String             @id @default(cuid())
  email          String             @unique
  passwordHash   String
  handle         String             @unique
  displayName    String?
  bio            String?
  location       String?
  website        String?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  repos          Repo[]
  collaborations RepoCollaborator[]
  pullRequests   PullRequest[]
  authoredIssues   Issue[]                    @relation("IssueAuthor")
  assignedIssues   Issue[]                    @relation("IssueAssignee")
  issueComments    IssueComment[]             @relation("IssueCommentAuthor")
  prComments       PullRequestComment[]       @relation("PRCommentAuthor")
  prReviews        PullRequestReview[]        @relation("PRReviewAuthor")
  prReviewComments PullRequestReviewComment[] @relation("PRReviewCommentAuthor")
  resolvedReviewComments PullRequestReviewComment[] @relation("PRReviewCommentResolver")
  releases         Release[]                  @relation("ReleaseAuthor")
  releaseAssets    ReleaseAsset[]             @relation("ReleaseAssetUploader")
  notifications    Notification[]
  personalAccessTokens PersonalAccessToken[]
  savedFilters     SavedFilter[]              @relation("SavedFilterOwner")
}

model PersonalAccessToken {
  id          String    @id @default(cuid())
  userId      String
  name        String
  tokenHash   String    @unique
  tokenPrefix String
  expiresAt   DateTime?
  lastUsedAt  DateTime?
  createdAt   DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Repo {
  id            String             @id @default(cuid())
  name          String
  description   String?
  visibility    RepoVisibility     @default(PUBLIC)
  storageKey    String?            @unique
  ownerId       String
  owner         User               @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  collaborators     RepoCollaborator[]
  snapshots         Snapshot[]
  pullRequests      PullRequest[]
  protectedBranches ProtectedBranch[]
  issues   Issue[]
  labels   Label[]
  releases Release[]
  notifications Notification[]
  topics          RepoTopic[]
  timelineEvents  TimelineEvent[]
  crossReferences CrossReference[]
  savedFilters    SavedFilter[]

  @@unique([ownerId, name])
}

// Repo discovery tags (GitHub-style topics). Lowercase-kebab, deduped per repo.
// Rendered as chips in the repo header and on dashboard/profile/search rows, and
// usable as a `topic:` filter in search. Owner/writer managed via repo settings.
model RepoTopic {
  id        String   @id @default(cuid())
  repoId    String
  topic     String
  createdAt DateTime @default(now())

  repo Repo @relation(fields: [repoId], references: [id], onDelete: Cascade)

  @@unique([repoId, topic])
  @@index([topic])
}

model RepoCollaborator {
  id        String           @id @default(cuid())
  repoId    String
  userId    String
  role      CollaboratorRole @default(READER)
  createdAt DateTime         @default(now())

  repo Repo @relation(fields: [repoId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([repoId, userId])
}

model Snapshot {
  id            String       @id @default(cuid())
  repoId        String
  handlerId     String       @default("gltf-scene")
  label         String?
  sourceFile    String
  schemaVersion String       @default("0.1.0")
  createdAt     DateTime     @default(now())
  gitCommitSha  String?
  /** UTF-8 payload for handlers that store inline text (e.g. plain-text); null for glTF scene snapshots. */
  snapshotBody  String?

  repo          Repo         @relation(fields: [repoId], references: [id], onDelete: Cascade)
  entities      Entity[]
  constraints   Constraint[]
}

model Entity {
  id             String       @id @default(cuid())
  snapshotId     String
  entityId       String
  parentEntityId String?
  kind           String
  name           String
  path           String
  posX           Float?
  posY           Float?
  posZ           Float?
  rotX           Float?
  rotY           Float?
  rotZ           Float?
  scaleX         Float?
  scaleY         Float?
  scaleZ         Float?
  attributes     String       @default("{}")
  renderRef      String?

  snapshot       Snapshot     @relation(fields: [snapshotId], references: [id], onDelete: Cascade)
  constraintsAsA Constraint[] @relation("ConstraintEntityA")
  constraintsAsB Constraint[] @relation("ConstraintEntityB")

  @@unique([snapshotId, entityId])
}

enum PRState {
  OPEN
  MERGED
  CLOSED
}

model PullRequest {
  id          String   @id @default(cuid())
  repoId      String
  number      Int
  title       String
  description String?
  fromBranch  String
  toBranch    String
  state       PRState  @default(OPEN)
  mergedAt    DateTime?
  /** How the PR was merged: "merge" | "squash" | "rebase". Null until merged. */
  mergeMethod    String?
  /** SHA of the resulting merge/squash/rebase commit on the base branch. Null until merged. Needed to revert. */
  mergeCommitSha String?
  authorId    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  repo           Repo                       @relation(fields: [repoId], references: [id], onDelete: Cascade)
  author         User                       @relation(fields: [authorId], references: [id])
  comments       PullRequestComment[]
  reviews        PullRequestReview[]
  reviewComments PullRequestReviewComment[]

  @@unique([repoId, number])
}

model ProtectedBranch {
  id     String @id @default(cuid())
  repoId String
  branch String

  repo Repo @relation(fields: [repoId], references: [id], onDelete: Cascade)

  @@unique([repoId, branch])
}

model Constraint {
  id            String   @id @default(cuid())
  snapshotId    String
  entityAId     String
  entityBId     String
  positionFixed Boolean  @default(true)
  rotationFixed Boolean  @default(true)
  createdAt     DateTime @default(now())

  snapshot Snapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)
  entityA  Entity   @relation("ConstraintEntityA", fields: [entityAId], references: [id], onDelete: Cascade)
  entityB  Entity   @relation("ConstraintEntityB", fields: [entityBId], references: [id], onDelete: Cascade)

  @@unique([snapshotId, entityAId, entityBId])
}

enum ReviewState {
  PENDING
  APPROVED
  CHANGES_REQUESTED
  COMMENTED
}

enum IssueState {
  OPEN
  CLOSED
}

model Label {
  id          String      @id @default(cuid())
  repoId      String
  name        String
  color       String
  description String?
  createdAt   DateTime    @default(now())

  repo   Repo        @relation(fields: [repoId], references: [id], onDelete: Cascade)
  issues IssueLabel[]

  @@unique([repoId, name])
}

model Issue {
  id         String     @id @default(cuid())
  repoId     String
  number     Int
  title      String
  body       String?
  state      IssueState @default(OPEN)
  authorId   String
  assigneeId String?
  closedAt   DateTime?
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  // ─── Time tracking (issue #122 · quick-actions) ───────────────────────────────
  // GitLab-style time tracking, stored as whole minutes. `estimateMinutes` is an
  // absolute target set by /estimate; `spentMinutes` accumulates via /spend (and
  // is floored at 0). Kept in their own block so the concurrent triage work
  // (pinning / locking fields on this same model) merges without conflict.
  estimateMinutes Int @default(0)
  spentMinutes    Int @default(0)
  // ──────────────────────────────────────────────────────────────────────────────

  // ─── Issue triage (issue #120): pinning + locking ─────────────────────────────
  // Owned by the ISSUE-TRIAGE feature. Kept in one block so a concurrent edit that
  // adds other Issue fields (quick-actions round) merges trivially.
  //   pinnedAt   — non-null ⇒ pinned; capped at 3 per repo (enforced in routes),
  //                surfaced in a distinct card row above the list, newest-pin first.
  //   locked     — when true, only writers may comment (API-enforced); the composer
  //                is replaced by a "Conversation locked" banner for non-writers.
  //   lockedAt / lockedById / lockReason — denormalized lock provenance for display.
  pinnedAt   DateTime?
  locked     Boolean    @default(false)
  lockedAt   DateTime?
  lockedById String?
  lockReason String?

  repo     Repo          @relation(fields: [repoId], references: [id], onDelete: Cascade)
  author   User          @relation("IssueAuthor",   fields: [authorId],   references: [id])
  assignee User?         @relation("IssueAssignee", fields: [assigneeId], references: [id])
  labels   IssueLabel[]
  comments IssueComment[]

  @@unique([repoId, number])
}

model IssueLabel {
  issueId String
  labelId String

  issue Issue @relation(fields: [issueId], references: [id], onDelete: Cascade)
  label Label @relation(fields: [labelId], references: [id], onDelete: Cascade)

  @@id([issueId, labelId])
}

model IssueComment {
  id        String   @id @default(cuid())
  issueId   String
  authorId  String
  body      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  issue  Issue @relation(fields: [issueId], references: [id], onDelete: Cascade)
  author User  @relation("IssueCommentAuthor", fields: [authorId], references: [id])
}

// ─── Saved filter views (issue #120) ─────────────────────────────────────────────

/**
 * A named, per-user snapshot of the issue/PR list filter bar — the
 * state/label/assignee/author/sort/search combo serialized as a query string.
 * Applied via a saved-views dropdown and shareable `?view=<id>` links. Pure
 * metadata over the existing filtering: deleting one never touches issues.
 * Scoped to a repo AND its owning user (each user keeps their own views), reusing
 * the spine's ConversationSubjectType so the same model serves PR views later.
 */
model SavedFilter {
  id        String                  @id @default(cuid())
  repoId    String
  ownerId   String
  name      String
  query     String
  scope     ConversationSubjectType @default(ISSUE)
  createdAt DateTime                @default(now())
  updatedAt DateTime                @updatedAt

  repo  Repo @relation(fields: [repoId], references: [id], onDelete: Cascade)
  owner User @relation("SavedFilterOwner", fields: [ownerId], references: [id], onDelete: Cascade)

  @@unique([repoId, ownerId, scope, name])
  @@index([repoId, ownerId])
}

// ─── Conversation spine: timeline events + cross-references ──────────────────────

/** Whether a timeline event or cross-reference targets an issue or a pull request. */
enum ConversationSubjectType {
  ISSUE
  PULL_REQUEST
}

/** Which body-bearing entity a cross-reference was parsed from. */
enum CrossRefSourceType {
  ISSUE
  ISSUE_COMMENT
  PULL_REQUEST
  PR_COMMENT
  PR_REVIEW_COMMENT
}

/**
 * Append-only conversation event (labeled, assigned, closed, merged, referenced,
 * head_pushed, …). Keyed by (repo, subjectType, subjectNumber) so it can be read
 * straight from the URL without an id lookup. Denormalized display data (actor
 * handle, label name/color, ref source) lives in `data` (JSON string) so history
 * survives label/user deletion — no FKs to mutable records. `data` is a JSON
 * string rather than a Json column because the datasource is SQLite (matching the
 * repo's existing String-encoded-JSON convention, e.g. DiffCache.result).
 */
model TimelineEvent {
  id            String                  @id @default(cuid())
  repoId        String
  subjectType   ConversationSubjectType
  subjectNumber Int
  kind          String
  actorId       String
  data          String                  @default("{}")
  createdAt     DateTime                @default(now())

  repo Repo @relation(fields: [repoId], references: [id], onDelete: Cascade)

  @@index([repoId, subjectType, subjectNumber, createdAt])
}

/**
 * A `#N` / `!N` reference parsed out of a body, linking a source (issue/PR/comment)
 * to a target issue or PR. `isClosingRef` marks `closes|fixes|resolves #N` from a
 * PR description so the target is closed on merge. Re-parsed on every edit; rows
 * for a source are diffed (added/removed) against the parsed set.
 */
model CrossReference {
  id           String                  @id @default(cuid())
  repoId       String
  sourceType   CrossRefSourceType
  sourceId     String
  targetType   ConversationSubjectType
  targetId     String
  targetNumber Int
  actorId      String
  isClosingRef Boolean                 @default(false)
  createdAt    DateTime                @default(now())

  repo Repo @relation(fields: [repoId], references: [id], onDelete: Cascade)

  @@unique([sourceType, sourceId, targetType, targetId])
  @@index([targetType, targetId])
}

enum NotificationReason {
  ASSIGNED
  COMMENT
  REVIEW_REQUESTED
  SUBSCRIBED
  MENTIONED
}

enum NotificationSubjectType {
  ISSUE
  PULL_REQUEST
  RELEASE
}

model Notification {
  id           String                  @id @default(cuid())
  userId       String
  repoId       String
  subjectType  NotificationSubjectType
  subjectId    String
  subjectTitle String
  reason       NotificationReason
  read         Boolean                 @default(false)
  createdAt    DateTime                @default(now())
  updatedAt    DateTime                @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  repo Repo @relation(fields: [repoId], references: [id], onDelete: Cascade)

  @@unique([userId, subjectId])
  @@index([userId, read])
}

model Release {
  id           String   @id @default(cuid())
  repoId       String
  tagName      String
  name         String
  body         String?
  isDraft      Boolean  @default(false)
  isPrerelease Boolean  @default(false)
  authorId     String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  repo   Repo @relation(fields: [repoId], references: [id], onDelete: Cascade)
  author User @relation("ReleaseAuthor", fields: [authorId], references: [id])
  assets ReleaseAsset[]

  @@unique([repoId, tagName])
}

model ReleaseAsset {
  id            String   @id @default(cuid())
  releaseId     String
  name          String
  contentType   String
  size          Int
  storageKey    String
  downloadCount Int      @default(0)
  uploadedById  String
  createdAt     DateTime @default(now())

  release    Release @relation(fields: [releaseId], references: [id], onDelete: Cascade)
  uploadedBy User    @relation("ReleaseAssetUploader", fields: [uploadedById], references: [id])

  @@unique([releaseId, name])
}

model PullRequestComment {
  id            String      @id @default(cuid())
  pullRequestId String
  authorId      String
  body          String
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  pullRequest   PullRequest @relation(fields: [pullRequestId], references: [id], onDelete: Cascade)
  author        User        @relation("PRCommentAuthor", fields: [authorId], references: [id])
}

model PullRequestReview {
  id            String      @id @default(cuid())
  pullRequestId String
  authorId      String
  state         ReviewState @default(PENDING)
  body          String?
  submittedAt   DateTime?
  /**
   * Head (`fromBranch`) commit SHA at submission time; null for pending reviews.
   * Staleness is computed, not stored: a submitted review is "stale" when this
   * SHA differs from the PR head's current SHA (dismiss-on-push). Kept as a value
   * rather than a flag so a force-push back to the reviewed SHA un-stales it.
   */
  commitSha     String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  pullRequest   PullRequest              @relation(fields: [pullRequestId], references: [id], onDelete: Cascade)
  author        User                     @relation("PRReviewAuthor", fields: [authorId], references: [id])
  comments      PullRequestReviewComment[]
}

model DiffCache {
  id          String   @id @default(cuid())
  handlerId   String
  baseBlobSha String
  headBlobSha String
  result      String   // JSON-encoded StructuredDiff
  createdAt   DateTime @default(now())

  @@unique([handlerId, baseBlobSha, headBlobSha])
}

model PullRequestReviewComment {
  id            String            @id @default(cuid())
  reviewId      String
  pullRequestId String
  authorId      String
  body          String
  filePath      String
  position      String
  /**
   * Threads: a root comment has `inReplyToId` null; replies point at the root.
   * Resolution state (resolvedAt/resolvedById) lives on the root comment only —
   * a resolved root collapses the whole thread in the UI. Replies attach to the
   * root's review, so answering a reviewer never opens a new pending review.
   */
  inReplyToId   String?
  resolvedAt    DateTime?
  resolvedById  String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  review        PullRequestReview @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  pullRequest   PullRequest       @relation(fields: [pullRequestId], references: [id], onDelete: Cascade)
  author        User              @relation("PRReviewCommentAuthor", fields: [authorId], references: [id])
  resolvedBy    User?             @relation("PRReviewCommentResolver", fields: [resolvedById], references: [id])
  inReplyTo     PullRequestReviewComment?  @relation("ReviewCommentThread", fields: [inReplyToId], references: [id], onDelete: Cascade)
  replies       PullRequestReviewComment[] @relation("ReviewCommentThread")

  @@index([pullRequestId, inReplyToId])
}
