generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum RepoVisibility {
  PUBLIC
  PRIVATE
}

enum CollaboratorRole {
  READER
  WRITER
}

model User {
  id             String             @id @default(cuid())
  email          String             @unique
  passwordHash   String
  handle         String             @unique
  displayName    String?
  // Global opt-in for email delivery of notifications. Default OFF so existing
  // users are never surprised by mail; they enable it from the Notifications page.
  emailNotifications Boolean         @default(false)
  bio            String?
  location       String?
  website        String?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  repos          Repo[]
  collaborations RepoCollaborator[]
  pullRequests   PullRequest[]
  authoredIssues   Issue[]                    @relation("IssueAuthor")
  assignedIssues   Issue[]                    @relation("IssueAssignee")
  issueComments    IssueComment[]             @relation("IssueCommentAuthor")
  prComments       PullRequestComment[]       @relation("PRCommentAuthor")
  prReviews        PullRequestReview[]        @relation("PRReviewAuthor")
  prReviewComments PullRequestReviewComment[] @relation("PRReviewCommentAuthor")
  resolvedReviewComments PullRequestReviewComment[] @relation("PRReviewCommentResolver")
  releases         Release[]                  @relation("ReleaseAuthor")
  releaseAssets    ReleaseAsset[]             @relation("ReleaseAssetUploader")
  notifications    Notification[]
  personalAccessTokens PersonalAccessToken[]
  savedFilters     SavedFilter[]              @relation("SavedFilterOwner")
  addedProjectItems ProjectItem[]             @relation("ProjectItemAddedBy")
  designs          Design[]                   @relation("DesignCreator")
  designVersions   DesignVersion[]            @relation("DesignVersionUploader")
  sshKeys          SSHKey[]
  sessions         Session[]
}

model PersonalAccessToken {
  id          String    @id @default(cuid())
  userId      String
  name        String
  tokenHash   String    @unique
  tokenPrefix String
  // ─── PAT scopes (issue #87) ───────────────────────────────────────────────────
  // Comma-separated scope list. v0 set: `repo:read`, `repo:write`, `admin`
  // (see src/scopes.ts). The default is the FULL set so tokens minted before this
  // column existed keep working exactly as they did (any PAT = full-power) — the
  // migration backfills existing rows with this default. New tokens choose a subset
  // at creation. Enforced in the auth preHandlers + the git-http write path.
  scopes      String    @default("repo:read,repo:write,admin")
  expiresAt   DateTime?
  lastUsedAt  DateTime?
  createdAt   DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Repo {
  id            String             @id @default(cuid())
  name          String
  description   String?
  visibility    RepoVisibility     @default(PUBLIC)
  storageKey    String?            @unique
  ownerId       String
  owner         User               @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  collaborators     RepoCollaborator[]
  snapshots         Snapshot[]
  pullRequests      PullRequest[]
  protectedBranches ProtectedBranch[]
  protectedTags     ProtectedTag[]
  issues   Issue[]
  labels   Label[]
  milestones Milestone[]
  releases Release[]
  notifications Notification[]
  topics          RepoTopic[]
  timelineEvents  TimelineEvent[]
  crossReferences CrossReference[]
  savedFilters    SavedFilter[]
  webhooks        Webhook[]
  workflowRuns    WorkflowRun[]

  projects        Project[]
  deployKeys      DeployKey[]

  // Fork lineage (issue #113): the repo this was forked from (null for roots),
  // and the inbound forks that point back at this repo. onDelete: SetNull so
  // deleting an upstream orphans its forks rather than cascade-deleting them.
  forkedFromId    String?
  forkedFrom      Repo?              @relation("RepoForks", fields: [forkedFromId], references: [id], onDelete: SetNull)
  forks           Repo[]             @relation("RepoForks")

  @@unique([ownerId, name])
}

// Repo discovery tags (GitHub-style topics). Lowercase-kebab, deduped per repo.
// Rendered as chips in the repo header and on dashboard/profile/search rows, and
// usable as a `topic:` filter in search. Owner/writer managed via repo settings.
model RepoTopic {
  id        String   @id @default(cuid())
  repoId    String
  topic     String
  createdAt DateTime @default(now())

  repo Repo @relation(fields: [repoId], references: [id], onDelete: Cascade)

  @@unique([repoId, topic])
  @@index([topic])
}

model RepoCollaborator {
  id        String           @id @default(cuid())
  repoId    String
  userId    String
  role      CollaboratorRole @default(READER)
  createdAt DateTime         @default(now())

  repo Repo @relation(fields: [repoId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([repoId, userId])
}

model Snapshot {
  id            String       @id @default(cuid())
  repoId        String
  handlerId     String       @default("gltf-scene")
  label         String?
  sourceFile    String
  schemaVersion String       @default("0.1.0")
  createdAt     DateTime     @default(now())
  gitCommitSha  String?
  /** UTF-8 payload for handlers that store inline text (e.g. plain-text); null for glTF scene snapshots. */
  snapshotBody  String?

  repo          Repo         @relation(fields: [repoId], references: [id], onDelete: Cascade)
  entities      Entity[]
  constraints   Constraint[]
  designVersions DesignVersion[]
}

model Entity {
  id             String       @id @default(cuid())
  snapshotId     String
  entityId       String
  parentEntityId String?
  kind           String
  name           String
  path           String
  posX           Float?
  posY           Float?
  posZ           Float?
  rotX           Float?
  rotY           Float?
  rotZ           Float?
  scaleX         Float?
  scaleY         Float?
  scaleZ         Float?
  attributes     String       @default("{}")
  renderRef      String?

  snapshot       Snapshot     @relation(fields: [snapshotId], references: [id], onDelete: Cascade)
  constraintsAsA Constraint[] @relation("ConstraintEntityA")
  constraintsAsB Constraint[] @relation("ConstraintEntityB")

  @@unique([snapshotId, entityId])
}

enum PRState {
  OPEN
  MERGED
  CLOSED
}

model PullRequest {
  id          String   @id @default(cuid())
  repoId      String
  number      Int
  title       String
  description String?
  fromBranch  String
  toBranch    String
  state       PRState  @default(OPEN)
  mergedAt    DateTime?
  /** How the PR was merged: "merge" | "squash" | "rebase". Null until merged. */
  mergeMethod    String?
  /** SHA of the resulting merge/squash/rebase commit on the base branch. Null until merged. Needed to revert. */
  mergeCommitSha String?
  authorId    String
  // Milestone association (issue #83). Nullable; SetNull on milestone delete so
  // removing a milestone never deletes the PR. Writer-gated via the PATCH route.
  milestoneId String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  repo           Repo                       @relation(fields: [repoId], references: [id], onDelete: Cascade)
  author         User                       @relation(fields: [authorId], references: [id])
  milestone      Milestone?                 @relation(fields: [milestoneId], references: [id], onDelete: SetNull)
  comments       PullRequestComment[]
  reviews        PullRequestReview[]
  reviewComments PullRequestReviewComment[]

  @@unique([repoId, number])
}

model ProtectedBranch {
  id     String @id @default(cuid())
  repoId String
  branch String

  // Enforced protection rules (issue #85). A bare row (all defaults) preserves
  // the original behavior: the branch cannot be deleted. `requirePullRequest`
  // and `blockForcePush` are enforced at the git transport (pre-receive hook);
  // `requiredApprovals` and `requireGreenChecks` are enforced at the merge
  // endpoints. Exact branch names only in v0 (glob patterns are a follow-up).
  requirePullRequest Boolean @default(false)
  requiredApprovals  Int     @default(0)
  requireGreenChecks Boolean @default(false)
  blockForcePush     Boolean @default(false)

  repo Repo @relation(fields: [repoId], references: [id], onDelete: Cascade)

  @@unique([repoId, branch])
}

model Constraint {
  id            String   @id @default(cuid())
  snapshotId    String
  entityAId     String
  entityBId     String
  positionFixed Boolean  @default(true)
  rotationFixed Boolean  @default(true)
  createdAt     DateTime @default(now())

  snapshot Snapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)
  entityA  Entity   @relation("ConstraintEntityA", fields: [entityAId], references: [id], onDelete: Cascade)
  entityB  Entity   @relation("ConstraintEntityB", fields: [entityBId], references: [id], onDelete: Cascade)

  @@unique([snapshotId, entityAId, entityBId])
}

enum ReviewState {
  PENDING
  APPROVED
  CHANGES_REQUESTED
  COMMENTED
}

enum IssueState {
  OPEN
  CLOSED
}

enum MilestoneState {
  OPEN
  CLOSED
}

// ─── Milestones (issue #83) ──────────────────────────────────────────────────────
//
// The lightest-weight planning primitive: a titled deliverable with an optional
// due date, grouping issues + PRs and surfacing a progress bar (closed vs total
// associated items, computed in the route — no denormalized counters at this
// scale). CRUD mirrors Label / routes/labels.ts, but keyed by a per-repo `number`
// (like Issue / PullRequest) so URLs read `…/milestones/3`. Deleting a milestone
// nulls out associations via `onDelete: SetNull` — it never deletes the items.
model Milestone {
  id          String         @id @default(cuid())
  repoId      String
  number      Int
  title       String
  description String?
  dueOn       DateTime?
  state       MilestoneState @default(OPEN)
  closedAt    DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  repo         Repo          @relation(fields: [repoId], references: [id], onDelete: Cascade)
  issues       Issue[]
  pullRequests PullRequest[]

  @@unique([repoId, number])
  @@unique([repoId, title])
}

model Label {
  id          String      @id @default(cuid())
  repoId      String
  name        String
  color       String
  description String?
  createdAt   DateTime    @default(now())

  repo   Repo        @relation(fields: [repoId], references: [id], onDelete: Cascade)
  issues IssueLabel[]

  @@unique([repoId, name])
}

model Issue {
  id         String     @id @default(cuid())
  repoId     String
  number     Int
  title      String
  body       String?
  state      IssueState @default(OPEN)
  authorId   String
  assigneeId String?
  closedAt   DateTime?
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  // ─── Time tracking (issue #122 · quick-actions) ───────────────────────────────
  // GitLab-style time tracking, stored as whole minutes. `estimateMinutes` is an
  // absolute target set by /estimate; `spentMinutes` accumulates via /spend (and
  // is floored at 0). Kept in their own block so the concurrent triage work
  // (pinning / locking fields on this same model) merges without conflict.
  estimateMinutes Int @default(0)
  spentMinutes    Int @default(0)
  // ──────────────────────────────────────────────────────────────────────────────

  // ─── Issue triage (issue #120): pinning + locking ─────────────────────────────
  // Owned by the ISSUE-TRIAGE feature. Kept in one block so a concurrent edit that
  // adds other Issue fields (quick-actions round) merges trivially.
  //   pinnedAt   — non-null ⇒ pinned; capped at 3 per repo (enforced in routes),
  //                surfaced in a distinct card row above the list, newest-pin first.
  //   locked     — when true, only writers may comment (API-enforced); the composer
  //                is replaced by a "Conversation locked" banner for non-writers.
  //   lockedAt / lockedById / lockReason — denormalized lock provenance for display.
  pinnedAt   DateTime?
  locked     Boolean    @default(false)
  lockedAt   DateTime?
  lockedById String?
  lockReason String?

  // ─── Milestone association (issue #83) ────────────────────────────────────────
  // Nullable; SetNull on milestone delete so removing a milestone never deletes
  // the issue. Writer-gated via the PATCH route + the /milestone quick action.
  milestoneId String?

  repo     Repo          @relation(fields: [repoId], references: [id], onDelete: Cascade)
  author   User          @relation("IssueAuthor",   fields: [authorId],   references: [id])
  assignee User?         @relation("IssueAssignee", fields: [assigneeId], references: [id])
  milestone Milestone?   @relation(fields: [milestoneId], references: [id], onDelete: SetNull)
  labels   IssueLabel[]
  comments IssueComment[]
  designs  Design[]

  @@unique([repoId, number])
}

model IssueLabel {
  issueId String
  labelId String

  issue Issue @relation(fields: [issueId], references: [id], onDelete: Cascade)
  label Label @relation(fields: [labelId], references: [id], onDelete: Cascade)

  @@id([issueId, labelId])
}

model IssueComment {
  id        String   @id @default(cuid())
  issueId   String
  authorId  String
  body      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  issue  Issue @relation(fields: [issueId], references: [id], onDelete: Cascade)
  author User  @relation("IssueCommentAuthor", fields: [authorId], references: [id])
}

// ─── Saved filter views (issue #120) ─────────────────────────────────────────────

/**
 * A named, per-user snapshot of the issue/PR list filter bar — the
 * state/label/assignee/author/sort/search combo serialized as a query string.
 * Applied via a saved-views dropdown and shareable `?view=<id>` links. Pure
 * metadata over the existing filtering: deleting one never touches issues.
 * Scoped to a repo AND its owning user (each user keeps their own views), reusing
 * the spine's ConversationSubjectType so the same model serves PR views later.
 */
model SavedFilter {
  id        String                  @id @default(cuid())
  repoId    String
  ownerId   String
  name      String
  query     String
  scope     ConversationSubjectType @default(ISSUE)
  createdAt DateTime                @default(now())
  updatedAt DateTime                @updatedAt

  repo  Repo @relation(fields: [repoId], references: [id], onDelete: Cascade)
  owner User @relation("SavedFilterOwner", fields: [ownerId], references: [id], onDelete: Cascade)

  @@unique([repoId, ownerId, scope, name])
  @@index([repoId, ownerId])
}

// ─── Conversation spine: timeline events + cross-references ──────────────────────

/** Whether a timeline event or cross-reference targets an issue or a pull request. */
enum ConversationSubjectType {
  ISSUE
  PULL_REQUEST
}

/** Which body-bearing entity a cross-reference was parsed from. */
enum CrossRefSourceType {
  ISSUE
  ISSUE_COMMENT
  PULL_REQUEST
  PR_COMMENT
  PR_REVIEW_COMMENT
}

/**
 * Append-only conversation event (labeled, assigned, closed, merged, referenced,
 * head_pushed, …). Keyed by (repo, subjectType, subjectNumber) so it can be read
 * straight from the URL without an id lookup. Denormalized display data (actor
 * handle, label name/color, ref source) lives in `data` (JSON string) so history
 * survives label/user deletion — no FKs to mutable records. `data` is a JSON
 * string rather than a Json column because the datasource is SQLite (matching the
 * repo's existing String-encoded-JSON convention, e.g. DiffCache.result).
 */
model TimelineEvent {
  id            String                  @id @default(cuid())
  repoId        String
  subjectType   ConversationSubjectType
  subjectNumber Int
  kind          String
  actorId       String
  data          String                  @default("{}")
  createdAt     DateTime                @default(now())

  repo Repo @relation(fields: [repoId], references: [id], onDelete: Cascade)

  @@index([repoId, subjectType, subjectNumber, createdAt])
}

/**
 * A `#N` / `!N` reference parsed out of a body, linking a source (issue/PR/comment)
 * to a target issue or PR. `isClosingRef` marks `closes|fixes|resolves #N` from a
 * PR description so the target is closed on merge. Re-parsed on every edit; rows
 * for a source are diffed (added/removed) against the parsed set.
 */
model CrossReference {
  id           String                  @id @default(cuid())
  repoId       String
  sourceType   CrossRefSourceType
  sourceId     String
  targetType   ConversationSubjectType
  targetId     String
  targetNumber Int
  actorId      String
  isClosingRef Boolean                 @default(false)
  createdAt    DateTime                @default(now())

  repo Repo @relation(fields: [repoId], references: [id], onDelete: Cascade)

  @@unique([sourceType, sourceId, targetType, targetId])
  @@index([targetType, targetId])
}

enum NotificationReason {
  ASSIGNED
  COMMENT
  REVIEW_REQUESTED
  SUBSCRIBED
  MENTIONED
}

enum NotificationSubjectType {
  ISSUE
  PULL_REQUEST
  RELEASE
}

model Notification {
  id           String                  @id @default(cuid())
  userId       String
  repoId       String
  subjectType  NotificationSubjectType
  subjectId    String
  subjectTitle String
  reason       NotificationReason
  read         Boolean                 @default(false)
  createdAt    DateTime                @default(now())
  updatedAt    DateTime                @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  repo Repo @relation(fields: [repoId], references: [id], onDelete: Cascade)

  @@unique([userId, subjectId])
  @@index([userId, read])
}

model Release {
  id           String   @id @default(cuid())
  repoId       String
  tagName      String
  name         String
  body         String?
  isDraft      Boolean  @default(false)
  isPrerelease Boolean  @default(false)
  authorId     String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  repo   Repo @relation(fields: [repoId], references: [id], onDelete: Cascade)
  author User @relation("ReleaseAuthor", fields: [authorId], references: [id])
  assets ReleaseAsset[]

  @@unique([repoId, tagName])
}

model ReleaseAsset {
  id            String   @id @default(cuid())
  releaseId     String
  name          String
  contentType   String
  size          Int
  storageKey    String
  downloadCount Int      @default(0)
  uploadedById  String
  createdAt     DateTime @default(now())

  release    Release @relation(fields: [releaseId], references: [id], onDelete: Cascade)
  uploadedBy User    @relation("ReleaseAssetUploader", fields: [uploadedById], references: [id])

  @@unique([releaseId, name])
}

model PullRequestComment {
  id            String      @id @default(cuid())
  pullRequestId String
  authorId      String
  body          String
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  pullRequest   PullRequest @relation(fields: [pullRequestId], references: [id], onDelete: Cascade)
  author        User        @relation("PRCommentAuthor", fields: [authorId], references: [id])
}

model PullRequestReview {
  id            String      @id @default(cuid())
  pullRequestId String
  authorId      String
  state         ReviewState @default(PENDING)
  body          String?
  submittedAt   DateTime?
  /**
   * Head (`fromBranch`) commit SHA at submission time; null for pending reviews.
   * Staleness is computed, not stored: a submitted review is "stale" when this
   * SHA differs from the PR head's current SHA (dismiss-on-push). Kept as a value
   * rather than a flag so a force-push back to the reviewed SHA un-stales it.
   */
  commitSha     String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  pullRequest   PullRequest              @relation(fields: [pullRequestId], references: [id], onDelete: Cascade)
  author        User                     @relation("PRReviewAuthor", fields: [authorId], references: [id])
  comments      PullRequestReviewComment[]
}

model DiffCache {
  id          String   @id @default(cuid())
  handlerId   String
  baseBlobSha String
  headBlobSha String
  result      String   // JSON-encoded StructuredDiff
  createdAt   DateTime @default(now())

  @@unique([handlerId, baseBlobSha, headBlobSha])
}

model PullRequestReviewComment {
  id            String            @id @default(cuid())
  reviewId      String
  pullRequestId String
  authorId      String
  body          String
  filePath      String
  position      String
  /**
   * Threads: a root comment has `inReplyToId` null; replies point at the root.
   * Resolution state (resolvedAt/resolvedById) lives on the root comment only —
   * a resolved root collapses the whole thread in the UI. Replies attach to the
   * root's review, so answering a reviewer never opens a new pending review.
   */
  inReplyToId   String?
  resolvedAt    DateTime?
  resolvedById  String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  review        PullRequestReview @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  pullRequest   PullRequest       @relation(fields: [pullRequestId], references: [id], onDelete: Cascade)
  author        User              @relation("PRReviewCommentAuthor", fields: [authorId], references: [id])
  resolvedBy    User?             @relation("PRReviewCommentResolver", fields: [resolvedById], references: [id])
  inReplyTo     PullRequestReviewComment?  @relation("ReviewCommentThread", fields: [inReplyToId], references: [id], onDelete: Cascade)
  replies       PullRequestReviewComment[] @relation("ReviewCommentThread")

  @@index([pullRequestId, inReplyToId])
}

// ─── Outbound webhooks (issue #87) ────────────────────────────────────────────────

/**
 * A repo-scoped outbound webhook. On each subscribed repo event the
 * webhook-service POSTs a signed JSON payload to `url`. `secret` keys the
 * HMAC-SHA256 body signature (X-ForgeHub-Signature-256). `events` is a
 * comma-separated subscription list ("push,issues,pull_request,release") or "*"
 * for all. Owner-only managed from repo settings. Best-effort delivery: a failure
 * never fails the originating request (mirrors the mailer side-channel).
 */
model Webhook {
  id        String   @id @default(cuid())
  repoId    String
  url       String
  secret    String
  events    String   @default("*")
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  repo       Repo              @relation(fields: [repoId], references: [id], onDelete: Cascade)
  deliveries WebhookDelivery[]

  @@index([repoId])
}

/**
 * One delivery ATTEMPT of a webhook. The retry policy records every attempt as
 * its own row (statusCode/ok/durationMs/error are per-attempt), so the deliveries
 * log shows the full picture including retries. `payload` is the exact raw body
 * that was signed and sent, so a manual redeliver replays byte-for-byte.
 * `redeliveredFromId` links a manual/retry replay back to the delivery it came
 * from (null for an original first attempt). `id` doubles as the
 * X-ForgeHub-Delivery header value.
 */
model WebhookDelivery {
  id                String   @id @default(cuid())
  webhookId         String
  event             String
  payload           String
  statusCode        Int?
  ok                Boolean  @default(false)
  durationMs        Int      @default(0)
  error             String?
  redeliveredFromId String?
  createdAt         DateTime @default(now())

  webhook Webhook @relation(fields: [webhookId], references: [id], onDelete: Cascade)

  @@index([webhookId, createdAt])
}

// ─── Actions-style CI: workflow runs + check runs (issue #86) ─────────────────────
//
// A repo-defined workflow (`.forgehub/workflows/*.yml`) triggered on a push or a
// pull_request event runs as a WorkflowRun holding one CheckRun per job. Status /
// conclusion are stored as lowercase strings (not enums) so they serialize
// straight into the `/check-summary` and run-detail responses that the merge box,
// commit status dots, and branch protection (#85) consume — matching the
// lowercase convention already used by Webhook.event. Logs never live in the DB:
// each CheckRun points at a file under `<GIT_STORAGE_ROOT>-ci/…` (see
// git-storage.ts, mirroring the release-asset `<root>-assets` sibling).
//
//   status:     "queued" | "running" | "completed"
//   conclusion: "success" | "failure" | null   (null until completed)
//   trigger/event of a run: "push" | "pull_request"

model WorkflowRun {
  id           String    @id @default(cuid())
  repoId       String
  // The commit the run was triggered for (branch tip for push, PR head for
  // pull_request). This is the SHA the /check-summary + status dots key on.
  commitSha    String
  // "push" | "pull_request".
  trigger      String
  // Ref that triggered the run: branch name (push) or PR head branch (pull_request).
  ref          String?
  // Set for pull_request runs so the PR Checks section can find its runs.
  prId         String?
  // Denormalized from the workflow file at trigger time.
  workflowName String
  workflowPath String
  // "queued" | "running" | "completed".
  status       String    @default("queued")
  // "success" | "failure" | null (null until completed).
  conclusion   String?
  createdAt    DateTime  @default(now())
  startedAt    DateTime?
  completedAt  DateTime?
  // Set when this run was created by re-running another run (POST …/rerun). Points
  // at the source WorkflowRun.id; null for runs created by a push/PR trigger. Kept
  // as a plain column (not a self-relation) so a pruned source never dangles a FK.
  rerunOfId    String?

  repo      Repo       @relation(fields: [repoId], references: [id], onDelete: Cascade)
  checkRuns CheckRun[]

  @@index([repoId, commitSha])
  @@index([repoId, createdAt])
  @@index([prId])
}

model CheckRun {
  id            String    @id @default(cuid())
  workflowRunId String
  // Stable job id from the workflow file (`jobs.<jobId>`), and its display name.
  jobId         String
  jobName       String
  // "queued" | "running" | "completed".
  status        String    @default("queued")
  // "success" | "failure" | null (null until completed).
  conclusion    String?
  startedAt     DateTime?
  completedAt   DateTime?
  // Absolute path to the interleaved stdout+stderr log on disk (null until the
  // job starts). Resolved via git-storage.ciLogPath.
  logPath       String?

  workflowRun WorkflowRun @relation(fields: [workflowRunId], references: [id], onDelete: Cascade)

  @@index([workflowRunId])
}

// ─── Projects: classic-style board + table over issues/PRs (issue #84) ───────────
//
// A repo-level project is a set of ordered status columns (seeded Todo /
// In progress / Done) holding items that each point at an issue or PR by number.
// The subject reference is polymorphic (subjectType + subjectNumber), mirroring
// the spine's TimelineEvent pattern, so an item survives without a hard FK to the
// mutable Issue/PullRequest row — the board hydrates by joining on
// (repoId, number) at read time and renders a graceful placeholder if the subject
// was deleted. Projects-v2-style custom fields are an explicit follow-up.

model Project {
  id          String   @id @default(cuid())
  repoId      String
  // Per-repo sequence number (like Issue/PullRequest), for clean URLs (/projects/1).
  number      Int
  name        String
  description String?
  // Closed = archived. Kept as a boolean (not a state enum) — a project is either
  // active or closed; there is no third state in v0.
  closed      Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  repo    Repo            @relation(fields: [repoId], references: [id], onDelete: Cascade)
  columns ProjectColumn[]
  items   ProjectItem[]

  @@unique([repoId, number])
}

model ProjectColumn {
  id        String   @id @default(cuid())
  projectId String
  name      String
  // Left-to-right order within the project. Renumbered densely (0,1,2,…) on write.
  position  Int
  createdAt DateTime @default(now())

  project Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  items   ProjectItem[]

  @@index([projectId])
}

model ProjectItem {
  id            String                  @id @default(cuid())
  // Denormalized projectId (alongside columnId) so a subject can be uniquely
  // constrained to at most one card per project across all its columns.
  projectId     String
  columnId      String
  subjectType   ConversationSubjectType
  subjectNumber Int
  // Vertical sort key within the column. Renumbered densely (0,1,2,…) on every
  // move — deterministic, so an optimistic client and the server always agree.
  position      Float
  addedById     String
  createdAt     DateTime                @default(now())

  project Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  column  ProjectColumn @relation(fields: [columnId], references: [id], onDelete: Cascade)
  addedBy User          @relation("ProjectItemAddedBy", fields: [addedById], references: [id])

  @@unique([projectId, subjectType, subjectNumber])
  @@index([columnId])
}

// ─── Design management (issue #121) ──────────────────────────────────────────────
//
// GitLab-style design management, reimagined for engineering files: design/artifact
// files attach directly to an ISSUE and version across uploads (uploading a file
// under the same design name bumps `currentVersion`). An FHR-recognized format is
// ingested into a Snapshot on upload (via the SAME handler.ingestFromUtf8Text
// pipeline commits use), so a version carries an entity tree — which lets
// version-vs-version compare reuse the SAME handler.diff() + DiffCache machinery as
// PR diffs (semantic where ingested, visual for images, byte summary otherwise).
// Handler eligibility is by extension via the global handler registry — designs are
// NOT commit-scoped, so there is no `.forge/formats` opt-in to consult. Bytes live
// on disk under `<GIT_STORAGE_ROOT>-designs/<repoId>/<designId>/<version>` (the
// release-asset sibling pattern), never in the DB.
model Design {
  id             String   @id @default(cuid())
  issueId        String
  name           String
  currentVersion Int      @default(0)
  createdById    String
  createdAt      DateTime @default(now())

  issue     Issue           @relation(fields: [issueId], references: [id], onDelete: Cascade)
  createdBy User            @relation("DesignCreator", fields: [createdById], references: [id])
  versions  DesignVersion[]

  @@unique([issueId, name])
}

model DesignVersion {
  id           String   @id @default(cuid())
  designId     String
  version      Int
  storageKey   String
  contentType  String
  size         Int
  // Set when the uploaded file was an FHR-recognized format and ingested into a
  // Snapshot (entity tree); null for images/binaries stored as-is. SetNull so a
  // snapshot deletion never removes the design version.
  snapshotId   String?
  uploadedById String
  createdAt    DateTime @default(now())

  design     Design    @relation(fields: [designId], references: [id], onDelete: Cascade)
  snapshot   Snapshot? @relation(fields: [snapshotId], references: [id], onDelete: SetNull)
  uploadedBy User      @relation("DesignVersionUploader", fields: [uploadedById], references: [id])

  @@unique([designId, version])
}

// ─── SSH keys + deploy keys + SSH git transport (issue #116) ──────────────────────
//
// Named, revocable public-key credentials, complementing the PAT/HTTPS path (#87)
// with the same "named credential" UX over a different transport. A user's SSHKey
// authorizes git-over-SSH as that user (their full repo access); a repo's DeployKey
// is repo-scoped for CI/automation and honors `readOnly`. The SSH front
// (src/ssh/server.ts) matches the presented public key's SHA256 fingerprint to one
// of these rows, resolves the actor, and invokes upload-pack / receive-pack through
// the SAME access checks + post-receive ingestion as git-http.ts. `fingerprint` is
// unique per table AND deduped across both tables at insert time (a key can back at
// most one credential anywhere). The stored `publicKey` is the normalized
// "type base64" OpenSSH line — public by nature, so it is safe to return.

model SSHKey {
  id          String    @id @default(cuid())
  userId      String
  title       String
  publicKey   String
  fingerprint String    @unique
  lastUsedAt  DateTime?
  createdAt   DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model DeployKey {
  id          String   @id @default(cuid())
  repoId      String
  title       String
  publicKey   String
  fingerprint String   @unique
  // Read-only by default: a deploy key clones/pulls but cannot push unless a repo
  // admin explicitly grants write. Enforced identically to git-http's canWrite.
  readOnly    Boolean  @default(true)
  createdAt   DateTime @default(now())

  repo Repo @relation(fields: [repoId], references: [id], onDelete: Cascade)

  @@index([repoId])
}

// ─── Interactive login sessions (issue #117) ──────────────────────────────────
//
// One row per interactive login (register / login). The JWT carries this row's
// id as a `sid` claim; the auth preHandler checks `revokedAt` on every request
// (revoked → 401) and stamps `lastSeenAt` (throttled). Lets a user list and
// revoke their active devices ("this device" / "everywhere"). Tokens minted
// before this feature carry no `sid` and remain valid but un-revocable
// individually — a global password change is the escape hatch there.
model Session {
  id         String    @id @default(cuid())
  userId     String
  userAgent  String?
  ip         String?
  createdAt  DateTime  @default(now())
  lastSeenAt DateTime  @default(now())
  revokedAt  DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ─── Protected tags (issue #117) ──────────────────────────────────────────────
//
// A glob pattern (`*` wildcard) matched against tag names. A matching tag cannot
// be deleted or overwritten — enforced both at the API tag routes and at the git
// transport, where the shared pre-receive hook reads a synced rules file (mirrors
// branch protection, issue #85). Creating a brand-new matching tag stays allowed,
// so releases keep working.
model ProtectedTag {
  id        String   @id @default(cuid())
  repoId    String
  pattern   String
  createdAt DateTime @default(now())

  repo Repo @relation(fields: [repoId], references: [id], onDelete: Cascade)

  @@unique([repoId, pattern])
  @@index([repoId])
}
