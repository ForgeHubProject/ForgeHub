DATABASE_URL="file:./dev.db"
JWT_SECRET="change-me-to-a-long-random-string"
PORT=3001

# Client / integration: base URL of this API (e.g. Git remote helper, CLI, Postman collection).
# FORGEHUB_API_URL="http://localhost:3001"

# On-disk root for bare Git repositories created by POST /repos.
GIT_STORAGE_ROOT="./git-storage"

# SSH git transport (issue #116). OFF unless FORGEHUB_SSH_PORT is set. When set,
# an ed25519 host key is generated/persisted at <GIT_STORAGE_ROOT>-ssh/host_key.
# FORGEHUB_SSH_PORT=22
# Optional host shown in the web clone box's ssh:// URL (defaults to the browser host).
# FORGEHUB_SSH_HOST="git.example.com"
