# Copy to .env before running `docker compose up` / `podman compose up`.

# Required. Generate with: openssl rand -base64 32
JWT_SECRET=

# Port the web container (nginx, serving the SPA + proxying /auth /repos /git etc.
# to the api container) publishes on the host. Default: 8080.
WEB_PORT=8080

# ─── Email notifications (issue #123) ─────────────────────────────────────────
# Public origin of this instance, used to build links and the one-click
# unsubscribe URL inside notification emails. In the container topology nginx
# serves both the SPA and the proxied API under this one origin.
# Default when unset: http://localhost:5173
PUBLIC_URL=

# SMTP delivery. When SMTP_URL (or SMTP_HOST) is set, notification emails are
# sent via nodemailer; otherwise a DEV transport appends each rendered email as
# a JSON line to <GIT_STORAGE_ROOT>/mail-outbox.jsonl so dev/self-host without
# SMTP still "delivers" somewhere inspectable.
#   SMTP_URL=smtp://user:pass@smtp.example.com:587
# ...or the discrete form:
#   SMTP_HOST=smtp.example.com
#   SMTP_PORT=587
#   SMTP_SECURE=false
#   SMTP_USER=
#   SMTP_PASS=
SMTP_URL=

# From: address on outgoing mail. Default: ForgeHub <no-reply@forgehub.local>
MAIL_FROM=

# HMAC secret for signing one-click unsubscribe tokens. Falls back to JWT_SECRET,
# then a fixed dev constant. Set this in production.
UNSUBSCRIBE_SECRET=
